# Copy to `.env.e2e` and fill in (`.env.e2e` is gitignored).
# `npm run test:e2e` loads this file automatically via `scripts/run-playwright.mjs`
# without overwriting variables you already exported in the shell.

# --- Real Supabase (required for login + authenticated specs) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Parent user for e2e/auth.setup.ts + e2e/authenticated/** ---
E2E_PARENT_EMAIL=
E2E_PARENT_PASSWORD=

# --- Full payment journey (e2e/parent-payment-flow.spec.ts) ---
# Requires Postgres (DATABASE_URL) so /api/test/setup-cart-scenario can insert enrollments,
# plus real Supabase keys so linkSupabaseAuth can create the seeded parent in Auth.
# DATABASE_URL=
# Optional override for X-Test-Token (defaults to test-secret-token, must match server dev).
# E2E_TEST_API_TOKEN=

# Optional: real keys reduce noisy logs during dev server boot
# OPENAI_API_KEY=
# Playwright’s webServer already sets sample Stripe test keys; override for real checkout E2E:
# TESTING_STRIPE_SECRET_KEY=
# VITE_TESTING_STRIPE_PUBLIC_KEY=
