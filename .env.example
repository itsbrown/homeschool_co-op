# Copy to `.env` and fill in. Used by `npm run dev` via `server/local-env.ts` (not committed).

# Postgres (dev + drizzle-kit push). Use a dedicated DB — never prod for tests.
# DATABASE_URL=postgresql://user:password@localhost:5432/asa_dev
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/asa_test

# https://supabase.com/dashboard/project/_/settings/api

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Client (Vite); usually same values as SUPABASE_* above
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Stripe test (see server/test-env-loader.ts)
TESTING_STRIPE_SECRET_KEY=sk_test_...
VITE_TESTING_STRIPE_PUBLIC_KEY=pk_test_...
